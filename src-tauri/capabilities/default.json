{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["*"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "autostart:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/slack-todos-sidecar",
          "sidecar": true
        }
      ]
    }
  ]
}
